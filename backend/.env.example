# PermitPulse Backend — Environment Variables
# Copy this file to .env and fill in your keys.

# Google Gemini API key — used by Railtracks for LLM calls (gemini-3.1-flash-lite-preview)
GOOGLE_API_KEY=your_google_api_key_here

# Senso.ai API key — used for knowledge base ingest + search
SENSO_API_KEY=your_senso_api_key_here

# (Optional) Socrata app token — raises DataSF rate limit from 1000 to 10000 req/hr
DATASF_APP_TOKEN=your_datasf_app_token_here
